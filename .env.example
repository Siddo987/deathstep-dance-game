# Single .env for the whole app - both the client (Vite, build-time) and the
# server (Node, runtime) read their variables from this one file.

# --- Client (Spotify Web Playback SDK) ---
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# --- Client + Server (Google Sign-In) ---
# Optional: enables the "Login with Google" button. Get this from the Google
# Cloud Console (OAuth 2.0 Client ID, type "Web application"). Both values
# must be the SAME client ID. Leave both unset to hide the Google button -
# email/password login keeps working either way.
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# --- Server: Database (MariaDB) ---
DB_HOST=your_db_host_here
DB_USER=your_db_user_here
DB_PASS=your_db_password_here
DB_NAME=your_db_name_here
# Optional, defaults to 3306
DB_PORT=

# --- Server: Auth ---
# Signs the login session cookie - set to a long random string, keep it secret
JWT_SECRET=change_me_to_a_long_random_string

# Set to "production" in deployment so login cookies are marked Secure (HTTPS-only)
NODE_ENV=development
